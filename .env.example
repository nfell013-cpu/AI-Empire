# ===========================================
# AI Empire - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ===========================================

# --- Database (Required) ---
# Supabase connection string with connection pooling
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrations (non-pooled)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- NextAuth.js (Required) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Your deployed app URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# --- Stripe (Required for Payments) ---
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Coinbase Commerce (Optional - Crypto Payments) ---
COINBASE_COMMERCE_API_KEY=""
COINBASE_WEBHOOK_SECRET=""

# --- AWS S3 (Required for File Uploads) ---
AWS_REGION="us-west-2"
AWS_BUCKET_NAME="your-bucket-name"
AWS_FOLDER_PREFIX="uploads/"
# Use explicit keys or AWS_PROFILE for IAM role-based auth
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# AWS_PROFILE="default"

# --- AI Services (Required for AI Features) ---
ABACUSAI_API_KEY="your-abacusai-api-key"
OPENAI_API_KEY="sk-..."

# --- Email Notifications (Optional) ---
RESEND_API_KEY="re_..."

# --- SMS Notifications (Optional) ---
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
