generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  firstName        String?
  lastName         String?
  role             String    @default("user")
  scanCount        Int       @default(0)
  freeScanUsed     Boolean   @default(false)
  stripeCustomerId String?

  // Generic subscriptions JSON – stores all 30 tool subscriptions
  // Shape: { "codeaudit_subscription": { active: true, subscriptionId: "...", expiresAt: "..." }, ... }
  subscriptions    Json      @default("{}")

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sessions         Session[]
  accounts         Account[]
  payments         Payment[]
  cryptoPayments   CryptoPayment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  stripeSessionId  String   @unique
  amount           Int      @default(999)
  productType      String?  // e.g., "codeaudit_subscription"
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CryptoPayment {
  id              String   @id @default(cuid())
  userId          String
  chargeId        String   @unique
  productType     String
  amount          Float
  currency        String   @default("USD")
  status          String   @default("pending")
  cryptoCurrency  String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
