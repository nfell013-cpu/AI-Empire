generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/ai_empire/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  firstName        String?
  lastName         String?
  role             String    @default("user")
  scanCount        Int       @default(0)
  freeScanUsed     Boolean   @default(false)
  stripeCustomerId String?
  // FlipScore subscription
  flipScoreSubscribed   Boolean   @default(false)
  flipScoreSubId        String?
  flipScoreSubExpiresAt DateTime?
  flipScoreScans        Int       @default(0)
  // TradeAce subscription
  tradeAceSubscribed    Boolean   @default(false)
  tradeAceSubId         String?
  tradeAceSubExpiresAt  DateTime?
  tradeAceStreak        Int       @default(0)
  tradeAceLastQuizDate  DateTime?
  tradeAceTotalQuizzes  Int       @default(0)
  tradeAceCorrectAnswers Int      @default(0)
  // DealDone subscription ($39/mo)
  dealDoneSubscribed    Boolean   @default(false)
  dealDoneSubId         String?
  dealDoneSubExpiresAt  DateTime?
  dealDoneNegotiations  Int       @default(0)
  // LeafCheck subscription ($12/mo)
  leafCheckSubscribed   Boolean   @default(false)
  leafCheckSubId        String?
  leafCheckSubExpiresAt DateTime?
  leafCheckScans        Int       @default(0)
  leafCheckFreeUsed     Boolean   @default(false)
  // PawPair one-time ($14)
  pawPairPurchased      Boolean   @default(false)
  pawPairPaymentId      String?
  pawPairQuizzes        Int       @default(0)
  // VisionLens subscription ($10/mo)
  visionLensSubscribed  Boolean   @default(false)
  visionLensSubId       String?
  visionLensSubExpiresAt DateTime?
  visionLensScans       Int       @default(0)
  visionLensFreeUsed    Boolean   @default(false)
  // CoachLogic subscription ($15/mo)
  coachLogicSubscribed  Boolean   @default(false)
  coachLogicSubId       String?
  coachLogicSubExpiresAt DateTime?
  coachLogicPlans       Int       @default(0)
  coachLogicFreePlanUsed Boolean  @default(false)
  // GlobeGuide subscription ($18/mo)
  globeGuideSubscribed  Boolean   @default(false)
  globeGuideSubId       String?
  globeGuideSubExpiresAt DateTime?
  globeGuideItineraries Int       @default(0)
  globeGuideFreeUsed    Boolean   @default(false)
  // SkillScope subscription ($16/mo)
  skillScopeSubscribed  Boolean   @default(false)
  skillScopeSubId       String?
  skillScopeSubExpiresAt DateTime?
  skillScopeAnalyses    Int       @default(0)
  skillScopeFreeUsed    Boolean   @default(false)
  // DataVault subscription ($22/mo)
  dataVaultSubscribed   Boolean   @default(false)
  dataVaultSubId        String?
  dataVaultSubExpiresAt DateTime?
  dataVaultReports      Int       @default(0)
  dataVaultFreeUsed     Boolean   @default(false)
  // GuardianAI subscription ($25/mo)
  guardianAISubscribed  Boolean   @default(false)
  guardianAISubId       String?
  guardianAISubExpiresAt DateTime?
  guardianAIScans       Int       @default(0)
  guardianAIFreeUsed    Boolean   @default(false)
  // TrendPulse subscription ($29/mo)
  trendPulseSubscribed  Boolean   @default(false)
  trendPulseSubId       String?
  trendPulseSubExpiresAt DateTime?
  trendPulseAnalyses    Int       @default(0)
  trendPulseFreeUsed    Boolean   @default(false)
  // SoundForge subscription ($20/mo)
  soundForgeSubscribed  Boolean   @default(false)
  soundForgeSubId       String?
  soundForgeSubExpiresAt DateTime?
  soundForgeTracks      Int       @default(0)
  soundForgeFreeUsed    Boolean   @default(false)
  // MemeMint subscription ($8/mo)
  memeMintSubscribed    Boolean   @default(false)
  memeMintSubId         String?
  memeMintSubExpiresAt  DateTime?
  memeMintCreations     Int       @default(0)
  memeMintFreeUsed      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sessions         Session[]
  accounts         Account[]
  scans            Scan[]
  payments         Payment[]
  thriftScans      ThriftScan[]
  tradeAceManuals  TradeAceManual[]
  tradeAceQuizzes  TradeAceQuiz[]
  dealDoneChats    DealDoneChat[]
  leafCheckScansRel LeafCheckScan[]
  pawPairResults   PawPairResult[]
  visionLensScansRel VisionLensScan[]
  coachLogicPlansRel CoachLogicPlan[]
  globeGuideTrips    GlobeGuideTrip[]
  skillScopeReports  SkillScopeReport[]
  dataVaultReportsRel DataVaultReport[]
  guardianAIScansRel GuardianAIScan[]
  trendPulseReports    TrendPulseReport[]
  soundForgeTracksRel  SoundForgeTrack[]
  memeMintCreationsRel MemeMintCreation[]
  cryptoPayments       CryptoPayment[]
  adViews              AdView[]
  // Token system
  tokens               Int       @default(100)
  tokenTransactions    TokenTransaction[]
}

// Token Transaction History
model TokenTransaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Int      // positive = credit, negative = debit
  balance         Int      // balance after transaction
  type            String   // 'usage' | 'purchase' | 'bonus' | 'refund'
  description     String
  toolSlug        String?  // which tool was used (for usage type)
  stripeSessionId String?  // for purchase transactions
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Token Package definitions (stored in config, this is for purchase records)
model TokenPurchase {
  id              String   @id @default(cuid())
  userId          String
  packageId       String   // starter, pro, business, enterprise
  tokenAmount     Int
  priceInCents    Int
  stripeSessionId String?  @unique
  status          String   @default("pending") // pending, completed, failed
  createdAt       DateTime @default(now())
  completedAt     DateTime?
}

model TradeAceManual {
  id               String   @id @default(cuid())
  userId           String
  fileName         String
  cloudStoragePath String?
  trade            String   // electrician, plumber, hvac
  title            String?
  pageCount        Int?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizzes          TradeAceQuiz[]
}

model TradeAceQuiz {
  id              String   @id @default(cuid())
  userId          String
  manualId        String?
  trade           String
  score           Int      @default(0)
  totalQuestions  Int      @default(10)
  completedAt     DateTime?
  questions       String   @db.Text // JSON string of questions/answers
  userAnswers     String?  @db.Text // JSON string of user's answers
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manual          TradeAceManual? @relation(fields: [manualId], references: [id])
}

model ThriftScan {
  id             String   @id @default(cuid())
  userId         String
  fileName       String
  cloudStoragePath String?
  itemName       String?
  category       String?
  condition      String?
  estimatedValue Float?
  purchasePrice  Float?
  potentialProfit Float?
  analysisResult String?  @db.Text
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Scan {
  id             String   @id @default(cuid())
  userId         String
  fileName       String
  cloudStoragePath String?
  analysisResult String?  @db.Text
  status         String   @default("pending")
  paymentId      String?
  isFree         Boolean  @default(false)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment        Payment? @relation(fields: [paymentId], references: [id])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  stripeSessionId  String   @unique
  amount           Int      @default(999)
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans            Scan[]
}

// DealDone - Brand Negotiation AI
model DealDoneChat {
  id              String   @id @default(cuid())
  userId          String
  brandName       String?
  originalMessage String   @db.Text
  counterOffer    String?  @db.Text
  fairRateMin     Float?
  fairRateMax     Float?
  negotiationTips String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// LeafCheck - Plant Species ID
model LeafCheckScan {
  id              String   @id @default(cuid())
  userId          String
  cloudStoragePath String?
  fileName        String
  plantName       String?
  scientificName  String?
  confidence      Float?
  careGuide       String?  @db.Text
  analysisResult  String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// PawPair - Pet Compatibility Quiz
model PawPairResult {
  id              String   @id @default(cuid())
  userId          String
  quizAnswers     String   @db.Text // JSON of quiz answers
  recommendedPets String?  @db.Text // JSON of pet recommendations
  topMatch        String?
  matchPercent    Int?
  matchReport     String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// VisionLens - Object ID + History + Value
model VisionLensScan {
  id              String   @id @default(cuid())
  userId          String
  cloudStoragePath String?
  fileName        String
  objectName      String?
  category        String?
  era             String?
  history         String?  @db.Text
  estimatedValue  Float?
  analysisResult  String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// CoachLogic - Practice Plan Generator
model CoachLogicPlan {
  id              String   @id @default(cuid())
  userId          String
  sport           String
  opponentNotes   String   @db.Text
  practiceGoals   String?  @db.Text
  planContent     String?  @db.Text // The generated practice plan
  duration        Int?     @default(60) // minutes
  pdfPath         String?  // Cloud storage path for PDF
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// GlobeGuide - AI Travel Itinerary Generator ($18/mo)
model GlobeGuideTrip {
  id              String   @id @default(cuid())
  userId          String
  destination     String
  startDate       DateTime?
  endDate         DateTime?
  duration        Int      // days
  budget          String?  // low, medium, high, luxury
  travelStyle     String?  // adventure, relaxation, cultural, foodie
  interests       String?  @db.Text // JSON array of interests
  itinerary       String?  @db.Text // Generated itinerary JSON
  tips            String?  @db.Text // Local tips and hidden gems
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// SkillScope - Resume Analyzer & Job Matcher ($16/mo)
model SkillScopeReport {
  id              String   @id @default(cuid())
  userId          String
  cloudStoragePath String?
  fileName        String
  jobDescription  String?  @db.Text
  resumeScore     Int?
  strengths       String?  @db.Text // JSON array
  weaknesses      String?  @db.Text // JSON array
  improvements    String?  @db.Text // JSON array
  matchedJobs     String?  @db.Text // JSON array of job matches
  analysisResult  String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// DataVault - Personal Finance Analyzer ($22/mo)
model DataVaultReport {
  id              String   @id @default(cuid())
  userId          String
  cloudStoragePath String?
  fileName        String
  totalIncome     Float?
  totalExpenses   Float?
  savingsRate     Float?
  spendingByCategory String? @db.Text // JSON object
  recommendations String?  @db.Text // JSON array
  monthlyTrends   String?  @db.Text // JSON array
  analysisResult  String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// GuardianAI - Online Reputation Monitor ($25/mo)
model GuardianAIScan {
  id              String   @id @default(cuid())
  userId          String
  searchQuery     String   // Name or brand to monitor
  scanType        String?  // personal, brand, business
  overallScore    Int?     // 0-100 reputation score
  positiveCount   Int?
  negativeCount   Int?
  neutralCount    Int?
  mentions        String?  @db.Text // JSON array of mentions
  recommendations String?  @db.Text // JSON array
  analysisResult  String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// TrendPulse - Market Trend Predictor ($29/mo)
model TrendPulseReport {
  id              String   @id @default(cuid())
  userId          String
  assetType       String   // stock, crypto, commodity
  assetName       String   // e.g., AAPL, BTC, Gold
  timeframe       String?  // short, medium, long
  sentiment       String?  // bullish, bearish, neutral
  confidenceScore Int?     // 0-100
  priceTargets    String?  @db.Text // JSON object with targets
  keyFactors      String?  @db.Text // JSON array
  riskLevel       String?  // low, medium, high
  analysisResult  String?  @db.Text
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// SoundForge - AI Music/Audio Generator ($20/mo)
model SoundForgeTrack {
  id              String   @id @default(cuid())
  userId          String
  genre           String   // ambient, electronic, hip-hop, rock, etc.
  mood            String   // energetic, calm, dark, uplifting, etc.
  duration        Int      @default(30) // seconds
  tempo           Int?     // BPM
  instruments     String?  @db.Text // JSON array of instruments
  prompt          String?  @db.Text // User description
  audioUrl        String?  // Generated audio URL
  status          String   @default("pending") // pending, generating, completed, failed
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// MemeMint - AI Meme Generator ($8/mo)
model MemeMintCreation {
  id              String   @id @default(cuid())
  userId          String
  template        String?  // meme template name
  topText         String?
  bottomText      String?
  prompt          String?  @db.Text // User's meme idea
  style           String?  // classic, modern, dark, wholesome
  generatedUrl    String?  // Generated meme URL
  viralScore      Int?     // 0-100 predicted virality
  suggestions     String?  @db.Text // JSON array of caption alternatives
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Advertiser Model
model Advertiser {
  id               String    @id @default(cuid())
  email            String    @unique
  companyName      String
  phone            String?
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  ads              Ad[]
  adPayments       AdPayment[]
}

// Ad Model
model Ad {
  id              String    @id @default(cuid())
  advertiserId    String
  title           String
  description     String    @db.Text
  adType          String    // VIDEO, IMAGE, TEXT
  adUrl           String?   // URL to the ad content
  duration        Int       // seconds
  targetApps      String[]  // array of app slugs
  cost            Int       // in cents
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, ACTIVE, PAUSED
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  tokensPerView   Int       @default(5)
  createdAt       DateTime  @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  adminNotes      String?   @db.Text
  advertiser      Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  adViews         AdView[]
  adPayments      AdPayment[]

  @@index([status])
  @@index([advertiserId])
}

// Ad View Model
model AdView {
  id              String   @id @default(cuid())
  adId            String
  userId          String
  tokensEarned    Int      @default(0)
  watchedFullAd   Boolean  @default(false)
  watchDuration   Int      @default(0) // seconds
  createdAt       DateTime @default(now())
  ad              Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([adId])
}

// Ad Payment Model
model AdPayment {
  id              String   @id @default(cuid())
  advertiserId    String
  adId            String
  amount          Int      // in cents
  stripePaymentId String?
  stripeSessionId String?  @unique
  status          String   @default("pending") // pending, completed, failed
  createdAt       DateTime @default(now())
  advertiser      Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  ad              Ad         @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([advertiserId])
}

// Crypto Payments - for all subscriptions
model CryptoPayment {
  id              String   @id @default(cuid())
  userId          String
  chargeId        String   @unique // Coinbase charge ID
  productType     String   // subscription type
  amount          Float    // USD amount
  currency        String   @default("USD")
  status          String   @default("pending") // pending, completed, failed, expired
  cryptoCurrency  String?  // BTC, ETH, USDC, etc.
  createdAt       DateTime @default(now())
  completedAt     DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
